{
  "name": "@kaleido-xlm/cli",
  "version": "0.1.4",
  "description": "Kaleido Stellar CLI for building dApps on Stellar/Soroban",
  "keywords": [
    "stellar",
    "soroban",
    "cli",
    "dapp",
    "smart-contracts",
    "blockchain",
    "web3",
    "kaleido"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dione-b/kaleido.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Dione-b/kaleido#readme",
  "author": "Kaleido Stellar contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "kaleido": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && rm -rf ./templates && cp -r ../templates ./templates",
    "dev": "tsx src/index.ts",
    "test": "vitest run --pool=threads",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kaleido-xlm/core": "^0.1.4",
    "chalk": "^5.4.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
