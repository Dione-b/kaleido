{
  "name": "@kaleido-xlm/core",
  "version": "0.1.2",
  "description": "Core config, artifacts, command orchestration, and error primitives for Kaleido Stellar/Soroban toolkit",
  "keywords": [
    "stellar",
    "soroban",
    "dapp",
    "smart-contracts",
    "blockchain",
    "artifacts",
    "kaleido"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dione-b/kaleido.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Dione-b/kaleido#readme",
  "author": "Kaleido Stellar contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run --pool=threads",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "execa": "^9.5.2",
    "jiti": "^2.4.2",
    "semver": "^7.8.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
